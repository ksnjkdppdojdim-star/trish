# Version cible des binaires a produire
TRISH_VERSION=1.23.00406

# Adresse IP ou nom DNS du poste qui heberge trish-server
TRISH_SERVER_ADDR=192.168.100.209

# Port TCP du serveur central Trish
TRISH_SERVER_PORT=9999

# Port annonce par l'agent dans son enregistrement
TRISH_AGENT_LISTEN_PORT=2222

# Optionnel: chemins perso pour le serveur
TRISH_SERVER_REGISTRY_PATH=C:\Users\<toi>\.trish\registry.json
TRISH_SERVER_LOCK_PATH=C:\Users\<toi>\.trish\server.lock

# Ces chemins sont aussi reutilises si tu installes trish-server.exe comme service Windows

# Secret partage pour signer les requetes admin CLI -> serveur
TRISH_ADMIN_SECRET=change-moi

# Optionnel: autoriser localhost pour les installs de test
TRISH_ALLOW_LOOPBACK_SERVER=false

# Optionnel: personnaliser les noms/chemins de sortie du build
TRISH_BUILD_OUTPUT_DIR=.
TRISH_BUILD_MAIN_NAME=trish.exe
TRISH_BUILD_CLI_NAME=trish-cli.exe
TRISH_BUILD_SERVER_NAME=trish-server.exe
TRISH_BUILD_AGENT_NAME=trish-agent.exe
